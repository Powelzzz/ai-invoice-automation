# OpenAI API key used for structured invoice field extraction
OPENAI_API_KEY=your_openai_api_key

# OpenAI model to use for extraction (e.g. gpt-4.1-mini, gpt-4o)
OPENAI_MODEL=gpt-4.1-mini

# OCR.Space API key used to convert invoice files into text
OCR_SPACE_API_KEY=your_ocr_space_api_key

# Google Drive folder ID where users upload invoice files
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# Google Sheet ID where processed invoice records are stored
GOOGLE_SHEET_ID=your_google_sheet_id

# Gmail address of the account used to send workflow notifications
GMAIL_SENDER=your_sender_email@example.com

# Gmail address that receives success and manual-review notifications
GMAIL_NOTIFICATION_TO=your_recipient_email@example.com
