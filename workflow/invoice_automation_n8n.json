    {
      "id": "8898ffcb-7ddc-4f21-bbb4-b46638833c5b",
      "name": "Normalize OCR Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -320,
        60
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const parsedText = ($json.ParsedResults?.[0]?.ParsedText || '').trim();\n\nlet trigger = {};\ntry {\n  trigger = $('Google Drive Trigger').first().json;\n} catch (e) {\n  trigger = $input.item.json || {};\n}\n\nreturn {\n  json: {\n    ocr_text: parsedText,\n    source_file_id: trigger.id || null,\n    source_file_name: trigger.name || null,\n    source_file_mime_type: trigger.mimeType || null,\n    source_file_created_time: trigger.createdTime || null,\n    source_file_link: trigger.webViewLink || null\n  }\n};"
      }
    },
    {
      "id": "5ef972a4-f5ab-4b79-a911-b24a1e8b3be9",
      "name": "OpenAI Extract Fields",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        -100,
        60
      ],
      "parameters": {
        "url": "https://api.openai.com/v1/chat/completions",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer REPLACE_WITH_OPENAI_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4.1-mini\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an AI assistant specialized in extracting structured financial data from invoice text. Return only a valid JSON object.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"You are an AI assistant specialized in extracting structured financial data from invoice text.\\n\\nYour task is to analyze the invoice content provided and return ONLY a valid JSON object following the exact format below.\\n\\nSTRICT RULES:\\n- Do NOT include any explanations, comments, markdown, or extra text.\\n- Output ONLY a valid JSON object.\\n- Do NOT guess or hallucinate missing values. If a value is not clearly present, return null.\\n- Ensure all extracted values come directly from the invoice text.\\n- All numeric values must be numbers only (no currency symbols, commas, or text).\\n- Dates must be formatted as YYYY-MM-DD if possible; otherwise return null.\\n- Currency must be a 3-letter code if identifiable (e.g., PHP, USD); otherwise return null.\\n- Ensure consistency: subtotal + tax ≈ total_amount when applicable.\\n- If multiple totals are present, choose the FINAL payable amount.\\n\\nFIELDS TO EXTRACT:\\n- vendor_name\\n- invoice_number\\n- invoice_date\\n- due_date\\n- currency\\n- subtotal\\n- tax\\n- total_amount\\n- suggested_category (choose ONLY one: Office Supplies, Utilities, Inventory Purchase, Freight, Repairs, Marketing, Other)\\n- confidence_notes\\n\\nOUTPUT FORMAT:\\n{\\n  \\\"vendor_name\\\": \\\"\\\",\\n  \\\"invoice_number\\\": \\\"\\\",\\n  \\\"invoice_date\\\": \\\"\\\",\\n  \\\"due_date\\\": \\\"\\\",\\n  \\\"currency\\\": \\\"\\\",\\n  \\\"subtotal\\\": null,\\n  \\\"tax\\\": null,\\n  \\\"total_amount\\\": null,\\n  \\\"suggested_category\\\": \\\"\\\",\\n  \\\"confidence_notes\\\": \\\"\\\"\\n}\\n\\nInvoice Text:\\n\\\"\\\"\\\"\\n{{$json.ocr_text}}\\n\\\"\\\"\\\"\"\n    }\n  ]\n}",
        "options": {}
      }
    },
    {
      "id": "1d5c74ff-b4d3-4bc0-9c4f-47dd1338d321",
      "name": "Parse Structured Invoice",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        140,
        60
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const rawContent = $json.choices?.[0]?.message?.content || '';\nlet parsed = {};\nlet parseError = null;\n\ntry {\n  parsed = JSON.parse(rawContent);\n} catch (error) {\n  parseError = `Invalid JSON from OpenAI: ${error.message}`;\n}\n\nconst missingFields = [];\nif (!parsed.vendor_name) missingFields.push('vendor_name');\nif (!parsed.invoice_number) missingFields.push('invoice_number');\n\nconst normalizedTotal = parsed.total_amount === null || parsed.total_amount === undefined || parsed.total_amount === ''\n  ? null\n  : Number(parsed.total_amount);\n\nif (normalizedTotal === null || Number.isNaN(normalizedTotal)) {\n  missingFields.push('total_amount');\n}\n\nconst confidenceText = String(parsed.confidence_notes || '').toLowerCase();\nconst lowConfidence = /uncertain|low confidence|missing|unclear|not found/.test(confidenceText);\nconst validationErrors = [];\nif (parseError) validationErrors.push(parseError);\nfor (const field of missingFields) validationErrors.push(`Missing required field: ${field}`);\nif (lowConfidence) validationErrors.push('Low confidence indicated by confidence_notes');\n\nlet normalizeData = {};\ntry {\n  normalizeData = $('Normalize OCR Text').first().json;\n} catch (e) {\n  normalizeData = {};\n}\n\nreturn {\n  json: {\n    source_file_name: normalizeData.source_file_name || null,\n    source_file_link: normalizeData.source_file_link || null,\n    source_file_created_time: normalizeData.source_file_created_time || null,\n    ocr_text: normalizeData.ocr_text || null,\n    openai_raw_content: rawContent,\n    vendor_name: parsed.vendor_name || null,\n    invoice_number: parsed.invoice_number || null,\n    invoice_date: parsed.invoice_date || null,\n    due_date: parsed.due_date || null,\n    currency: parsed.currency || null,\n    subtotal: parsed.subtotal === null || parsed.subtotal === undefined || parsed.subtotal === '' ? null : Number(parsed.subtotal),\n    tax: parsed.tax === null || parsed.tax === undefined || parsed.tax === '' ? null : Number(parsed.tax),\n    total_amount: normalizedTotal,\n    suggested_category: parsed.suggested_category || null,\n    confidence_notes: parsed.confidence_notes || null,\n    status: validationErrors.length === 0 ? 'Ready for review' : 'Manual Review',\n    review_needed: validationErrors.length === 0 ? 'No' : 'Yes',\n    validation_errors: validationErrors.join('; '),\n    is_valid: validationErrors.length === 0,\n    upload_timestamp: new Date().toISOString()\n  }\n};"
      }
    },
