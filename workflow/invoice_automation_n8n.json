{
  "id": "ai-invoice-automation-001",
  "name": "AI Invoice Processing and Accounting Entry Automation",
  "nodes": [
    {
      "id": "2b2e9fbb-1cf6-4662-9e42-c0aa03ef1a01",
      "name": "Setup Notes",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -1160,
        -420
      ],
      "parameters": {
        "color": 5,
        "width": 720,
        "height": 260,
        "content": "## Import Checklist\n\n1. Select your existing Google Drive, Google Sheets, and Gmail credentials on the Google nodes.\n2. Replace `YOUR_GOOGLE_DRIVE_FOLDER_ID` in the trigger.\n3. Replace `YOUR_GOOGLE_SHEET_ID` and `Sheet1` in both Google Sheets nodes.\n4. Replace OCR.Space and OpenAI placeholder headers in the two HTTP Request nodes.\n5. Update the Gmail `To` field if you want notifications sent to a different inbox.\n\nThis starter workflow is designed for a quick interview demo and includes a manual-review branch."
      }
    },
    {
      "id": "5a98f733-e52b-4e84-82f2-fd4522d7af02",
      "name": "Google Drive Trigger",
      "type": "n8n-nodes-base.googleDriveTrigger",
      "typeVersion": 1,
      "position": [
        -980,
        60
      ],
      "parameters": {
        "authentication": "oAuth2",
        "triggerOn": "specificFolder",
        "folderToWatch": {
          "__rl": true,
          "mode": "id",
          "value": "YOUR_GOOGLE_DRIVE_FOLDER_ID"
        },
        "event": "fileCreated",
        "options": {
          "fileType": "all"
        },
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        }
      }
    },
